@model DH52110843_web_quan_ly_khach_san_homestay.DTO.HotelsServiceDTO

@{
    ViewData["Title"] = "formAdd";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var hotel = ViewBag.DSKS as Hotel;
}


<div class="container mt-5">
    <h2 class="text-center mb-4 text-primary">Thêm Dịch Vụ Khách Sạn</h2>
    <form asp-action="addeHotelService" method="POST" onsubmit="return confirm('Bạn có chắc chắn muốn lưu dịch vụ này không?');">
            <div class="form-group" style="display: none;">
                <label asp-for="ServiceId" class="control-label"></label>
                <input asp-for="ServiceId" class="form-control" readonly="readonly" />
                <span asp-validation-for="ServiceId" class="text-danger"></span>
            </div>
            <!-- Tên dịch vụ -->
            <div class="form-group mb-3">
                <label for="ServiceName" class="form-label">Tên dịch vụ</label>
                <input asp-for="ServiceName" class="form-control" placeholder="Nhập tên dịch vụ" required />
                <span asp-validation-for="ServiceName" class="text-danger"></span>
            </div>

            <!-- Mô tả dịch vụ -->
            <div class="form-group mb-3">
                <label asp-for="ServiceInfo" class="form-label">Thông tin dịch vụ</label>
                <textarea asp-for="ServiceInfo" rows="4" class="form-control" placeholder="Nhập thông tin dịch vụ" required></textarea>
                <span asp-validation-for="ServiceInfo" class="text-danger"></span>
            </div>

            <!-- Khách sạn -->
            <div class="form-group mb-3">
                <label class="control-label">Khách sạn</label>
                <!-- Input hidden dùng để submit HotelId -->
                <input asp-for="HotelId" class="form-control" value="@hotel.HotelId" readonly hidden />
                <!-- Input readonly hiển thị tên khách sạn cho người xem -->
                <input class="form-control" value="@hotel?.HotelName" readonly />
                <span asp-validation-for="HotelId" class="text-danger"></span>
            </div>
@*             <div class="form-group mb-3">
                <label class="form-label">Khách sạn</label>
                <select asp-for="HotelId" asp-items="@ViewBag.DSKS" class="form-select"></select>
                <span asp-validation-for="HotelId" class="text-danger"></span>
            </div> *@

            <!-- Nút hành động -->
            <div class="form-actions mt-4 text-center">
                <button type="submit" class="btn btn-primary me-2">Lưu</button>
                <a asp-action="Index" asp-route-id ="@hotel.HotelId" class="btn btn-secondary">Hủy</a>
            </div>
        </form>
    </div>
</div>


