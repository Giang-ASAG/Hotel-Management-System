@model DH52110843_web_quan_ly_khach_san_homestay.Models.User

@{
    ViewData["Title"] = "formAdd";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}


<div class="container mt-5">
    <h2 class="text-center mb-4 text-primary">Thêm Người dùng</h2>
    <form asp-action="addUser" method="POST" onsubmit="return confirm('Bạn có chắc chắn muốn thêm người dùng này không?');">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="form-group" style="display:none">
            <label asp-for="UserId" class="control-label"></label>
            <input asp-for="UserId" class="form-control" />
            <span asp-validation-for="UserId" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="FullName" class="control-label">Họ tên:</label>
            <input asp-for="FullName" type="text" class="form-control" required/>
            <span asp-validation-for="FullName" class="text-danger"></span>
        </div>
        <div class="form-group" >
            <label asp-for="Password" class="control-label">Mật khẩu</label>
            <input asp-for="Password" type="password" class="form-control" required />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Email" class="control-label">Email:</label>
            <input asp-for="Email" type="email" class="form-control" required />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Address" class="control-label">Địa chỉ:</label>
            <input asp-for="Address" type="text" class="form-control" required />
            <span asp-validation-for="Address" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="PhoneNumber" class="control-label">Số điện thoại</label>
            <input asp-for="PhoneNumber" type="number" class="form-control" required />
            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Active" class="control-label">Hoạt động</label>
            <select asp-for="Active" class="form-control">
                <option value="">-- Chọn trạng thái --</option>
                <option value="false">Không hoạt động</option>
                <option value="true">Hoạt động</option>
            </select>
            <span asp-validation-for="Active" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="UserRoleId" class="control-label">Quyền</label>
            <select asp-for="UserRoleId" class="form-control">
                <option value="1">Quản trị</option>
                <option value="2">Người dùng</option>
                <option value="3">Đối tác</option>
            </select>
            <span asp-validation-for="UserRoleId" class="text-danger"></span>
        </div>

        <div class="form-actions mt-4 text-center">
            <button type="submit" class="btn btn-primary me-2">Lưu</button>
            <a asp-action="Index" class="btn btn-secondary">Hủy</a>
        </div>
    </form>
</div>


