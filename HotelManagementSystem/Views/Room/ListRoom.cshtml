@model IEnumerable<DH52110843_web_quan_ly_khach_san_homestay.Models.Room>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";

}

<div class="container mt-5">
    <div class="main">
        @if (TempData["SuccessMessage"] != null)
        {
                     <div id="alert" class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <!-- Tiêu đề và nút thêm mới -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="page-title m-0">Quản Lý Phòng Khách Sạn</h2>
            <div>

                <a asp-action="formAdd" asp-route-a="@Model.First().RoomTypeId">
                    <button class="btn btn-success me-2">+ Thêm mới</button>
                </a>
            </div>
        </div>

        <!-- Thông báo -->
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            Đây là danh sách các phòng trong khách sạn.
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
        </div>


        <!-- Bảng dữ liệu -->
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Số phòng</th>
                        <th scope="col">Trạng thái</th>
                        <th scope="col">Tình trạng</th>
                        <th scope="col">Thao tác</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @Html.DisplayFor(modelItem => item.RoomNumber)
                            </td>

                            <td>
                                @{
                                    string status;
                                    string badgeClass;

                                    if (item.Status)
                                    {
                                        status = "Đã đặt";
                                        badgeClass = "bg-danger"; // Màu đỏ khi đã đặt
                                    }
                                    else
                                    {
                                        status = "Còn phòng";
                                        badgeClass = "bg-success"; // Màu xanh khi còn phòng
                                    }
                                }
                                <span class="badge @badgeClass">@status</span>
                            </td>
                            <td>


                                @(item.Active ? "Hoạt động" : "Bảo trì")@*  Hoat dong = true *@
                            </td>


                            <td>
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-secondary dropdown-toggle" data-bs-toggle="dropdown">
                                        Tùy
                                        Chọn
                                    </button>
                                    <ul class="dropdown-menu">

                                        <li><a class="dropdown-item" asp-route-id="@item.RoomId" asp-action="formEdit">Chỉnh sửa</a></li>
                                        <form asp-action="delete" asp-route-id="@item.RoomId" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa phòng này?');">
                                            <input type="hidden" name="_method" value="DELETE" />
                                            <button type="submit" class="dropdown-item text-danger">Xóa</button>
                                        </form>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>




