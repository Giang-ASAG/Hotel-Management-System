@model DH52110843_web_quan_ly_khach_san_homestay.Models.RoomType

@{
    ViewData["Title"] = "formEdit";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var hotel = ViewBag.DSKS as Hotel;
}

    <h2 class="mb-4">Chỉnh Sửa Loại Phòng</h2>
    <div class="chi-tiet-form row g-4 bg-white">
    @if (TempData["SuccessMessage"] != null)
    {
                 <div id="alert" class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
        <!-- Ảnh phòng -->
        <div class="col-md-5">
            <div id="imageGallery" class="row g-2">
                @foreach (var i in Model.RoomImages)
                {
                    <div class="col-4 image-container">
                    <img src="@(i.Image.ImagePath)" class="img-fluid rounded object-fit-cover" alt="Room Image" />
                        <form method="post" asp-route-roomTypeId="@i.RoomTypeId" asp-action="deleteImage" asp-route-id="@i.RoomImageId" asp-route-a="@i.ImageId" onsubmit="return confirm('Bạn có chắc muốn xóa ảnh này không?');">
                            <input type="hidden" name="imagePath" value="@i.Image.ImagePath" />
                            <button type="submit" class="btn btn-danger btn-sm rounded-circle position-absolute top-0 end-0 m-1">✕</button>
                        </form>
                    </div>
                }
            </div>
            <div class="mt-3">
                @if (TempData["ImageSuccessMessage"] != null)
                {
                             <div id="alert" class="alert alert-success alert-dismissible fade show" role="alert">
                        @TempData["ImageSuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["ImageErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @TempData["ImageErrorMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
            <form id="addImageForm" method="post" asp-action="AddImage" asp-route-id="@Model.RoomTypeId" enctype="multipart/form-data" class="d-flex align-items-center mb-3">
                <div class="me-2 flex-grow-1">
                    <input type="file" id="imageInput" name="Images" accept="image/*" class="form-control" multiple required />
                </div>
                <button type="submit" class="btn btn-primary">Thêm Ảnh</button>
            </form>
            </div>
        </div>

        <!-- Form chỉnh sửa -->
        <div class="col-md-7">
        <form id="editRoomForm" method="post" asp-action="update" enctype="multipart/form-data" onsubmit="return confirm('Bạn có chắc chắn muốn lưu chỉnh sửa loại phòng này không?');">
            <div class="mb-3" style="display:none">
                <label class="control-label">ID</label>
                <input asp-for="RoomTypeId" class="form-control" required />
                <span asp-validation-for="RoomTypeId" class="text-danger"></span>
            </div>
                <div class="mb-3">
                    <label  class="control-label">Loại Phòng</label>
                    <input asp-for="TypeName" class="form-control" required/>
                    <span asp-validation-for="TypeName" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label class="control-label">Khách sạn</label>
                    <!-- Input hidden dùng để submit HotelId -->
                    <input asp-for="HotelId" class="form-control" value="@hotel.HotelId" hidden />
                    <!-- Input readonly hiển thị tên khách sạn cho người xem -->
                    <input class="form-control" value="@hotel?.HotelName"  readonly/>
                    <span asp-validation-for="HotelId" class="text-danger"></span>
                </div>
@*                 <div class="mb-3">
                    <label class="form-label">Khách sạn</label>
                    <select asp-for="HotelId" asp-items="@ViewBag.DSKS" class="form-select"></select>
                    <span asp-validation-for="HotelId" class="text-danger"></span>
                </div> *@
            <div class="mb-3">
                <label class="control-label">Giá tiền</label>
                <input asp-for="Price" class="form-control" required />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>
                <div class="mb-3">
                    <label class="control-label">Sức chứa</label>
                <input asp-for="Capacity" class="form-control" required />
                    <span asp-validation-for="Capacity" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label  class="control-label">Mô tả phòng</label>
                    <textarea class="form-control" id="description" asp-for="RoomInfo" rows="4" required></textarea>
                    <span asp-validation-for="RoomInfo" class="text-danger"></span>
                </div>
                <div class="mt-4">
                    <button type="submit" class="btn btn-primary me-2">Lưu</button>
                <a asp-action="Index" asp-route-id="@hotel?.HotelId" class="btn btn-secondary me-2">Quay lại danh sách</a>
                </div>
            </form>
        </div>
    </div>
</div>





