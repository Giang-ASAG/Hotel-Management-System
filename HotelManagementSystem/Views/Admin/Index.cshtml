@model int[]

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="row mt-4">
    <div class="col-md-10 mx-auto">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Thống kê người dùng theo tháng</h5>
                <canvas id="bieuDoNguoiDung" style="height:350px;"></canvas>
            </div>
        </div>
    </div>
</div>


@section Scripts {
<script>
    const ctx = document.getElementById('bieuDoNguoiDung').getContext('2d');
    const bieuDoNguoiDung = new Chart(ctx, {
        type: 'bar',
        data: {
                labels: ['Tháng 1', 'Tháng 2', 'Tháng 3', 'Tháng 4', 'Tháng 5', 'Tháng 6', 'Tháng 7', 'Tháng 8', 'Tháng 9', 'Tháng 10', 'Tháng 11','Tháng 12'],
            datasets: [{
                label: 'Người dùng đăng ký',
                    data: [@Model[0], @Model[1], @Model[2], @Model[3], @Model[4], @Model[5], @Model[6], @Model[7], @Model[8], @Model[9], @Model[10], @Model[11]],
                backgroundColor: '#0d6efd',
                borderRadius: 5
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: {
                    display: false
                },
                title: {
                    display: false
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    title: {
                        display: true,
                        text: 'Số lượng người dùng'
                    }
                },
                x: {
                    title: {
                        display: true,
                        text: 'Tháng'
                    }
                }
            }
        }
    });
</script>
}


