@model DH52110843_web_quan_ly_khach_san_homestay.Models.Hotel

@{
    ViewData["Title"] = "formEdit";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


    <h2 class="mb-4">Chỉnh Sửa Khách Sạn</h2>
    <div class="chi-tiet-form row g-4 bg-white">
    @if (TempData["SuccessMessage"] != null)
    {
                 <div id="alert" class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
        <!-- Ảnh phòng -->
        <div class="col-md-5">
            <div id="imageGallery" class="row g-2">
                @foreach (var i in Model.HotelImages)
                {
                    <div class="col-4 image-container">
                    <img src="@(i.Image.ImagePath)" class="img-fluid rounded object-fit-cover" alt="Room Image" />
                    <form method="post" asp-action="deleteImage" asp-route-hotel="@Model.HotelId" asp-route-id="@i.HotelImageId" asp-route-a="@i.ImageId" onsubmit="return confirm('Bạn có chắc muốn xóa ảnh này không?');">
                            <input type="hidden" name="imagePath" value="@i.Image.ImagePath" />
                            <button type="submit" class="btn btn-danger btn-sm rounded-circle position-absolute top-0 end-0 m-1">✕</button>
                        </form>
                    </div>
                }
            </div>
            <div class="mt-3">
                @if (TempData["ImageSuccessMessage"] != null)
                {
                             <div id="alert" class="alert alert-success alert-dismissible fade show" role="alert">
                        @TempData["ImageSuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["ImageErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @TempData["ImageErrorMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
            <form id="addImageForm" method="post" asp-action="AddImage" asp-route-id="@Model.HotelId" enctype="multipart/form-data" class="d-flex align-items-center mb-3">
                <div class="me-2 flex-grow-1">
                    <input type="file" id="imageInput" name="Images" accept="image/*" class="form-control" multiple required />
                </div>
                <button type="submit" class="btn btn-primary">Thêm Ảnh</button>
            </form>
            </div>
        </div>

        <!-- Form chỉnh sửa -->
        <div class="col-md-7">
        <form id="editRoomForm" method="post" asp-action="updateHotel" asp-controller="Hotel" enctype="multipart/form-data" onsubmit="return confirm('Bạn có chắc chắn muốn lưu chỉnh sửa loại phòng này không?');">
                <div class="mb-3" style="display:none">
                    <label asp-for="HotelId" class="control-label"></label>
                    <input asp-for="HotelId" class="form-control" />
                    <span asp-validation-for="HotelId" class="text-danger"></span>
                </div>
                <div class="mb-3" style="display:none">
                    <label asp-for="UserId" class="control-label"></label>
                    <input asp-for="UserId" class="form-control" />
                    <span asp-validation-for="UserId" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="HotelName" class="control-label"> Tên khách sạn</label>
                    <input asp-for="HotelName" class="form-control" />
                    <span asp-validation-for="HotelName" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Address" class="control-label">Địa chỉ: </label>
                    <input asp-for="Address" type="text" id="addressInput" class="form-control" autocomplete="off" required placeholder="Vui lòng nhập địa chỉ" />
                    <span asp-validation-for="Address" class="text-danger"></span>
                    <ul id="suggestionsList" class="list-group" style="display:none;"></ul>
                </div>
                <div class="mb-3">
                    <label asp-for="PhoneNumber" class="control-label">Số điện thoại</label>
                    <input asp-for="PhoneNumber" class="form-control" />
                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Email" class="control-label">Địa chỉ email</label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="mb-3" style="display:none">
                    <label asp-for="XCoordinate">Tọa độ vĩ độ (Latitude):</label>
                    <input asp-for="XCoordinate" type="text" id="latInput" class="form-control" hidden readonly />
                </div>

            <div class="mb-3" style="display:none">
                    <label asp-for="XCoordinate">Tọa độ kinh độ (Longitude):</label>
                    <input asp-for="YCoordinate" type="text" id="lngInput" class="form-control" hidden readonly />
                </div>
            <div class="mb-3">
                <label asp-for="Star" class="control-label"> Số sao</label>
                <select asp-for="Star" class="form-control">
                    <option value="">-- Chọn số sao --</option>
                    <option value="1">⭐</option>
                    <option value="2">⭐⭐</option>
                    <option value="3">⭐⭐⭐</option>
                    <option value="4">⭐⭐⭐⭐</option>
                    <option value="5">⭐⭐⭐⭐⭐</option>
                </select>
                <span asp-validation-for="Star" class="text-danger"></span>
            </div>
                <div class="mb-3">
                    <label asp-for="Status" class="control-label">Trạng thái</label>
                    <select asp-for="Status" class="form-control">
                        <option value="0">Không hoạt động</option>
                        <option value="1">Hoạt động</option>
                    </select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>
            <div class="mb-3">
                <label asp-for="Description" class="control-label">Mô tả</label>
                <textarea class="form-control" id="description" asp-for="Description" rows="4" required></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
                <div class="mt-4">
                    <button type="submit" class="btn btn-primary me-2">Lưu</button>
                <a asp-action="listhotel" asp-controller="Home" class="btn btn-secondary me-2">Quay lại danh sách</a>
                </div>
            </form>
        </div>
    </div>



@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#addressInput').on('input', function () {
                const input = $(this).val();
                const $suggestionsList = $('#suggestionsList');

                if (input.length > 2) {
                    $.getJSON('/Hotel/GetAddressSuggestions', { input })
                        .done(data => {
                            $suggestionsList.empty().toggle(!!data.length);
                            data.forEach(item => {
                                $suggestionsList.append(
                                    `<li class="list-group-item suggestion-item" data-place-id="${item.place_id}">${item.description}</li>`
                                );
                            });
                        })
                        .fail(() => {
                            $suggestionsList.hide();
                            console.error('Error fetching suggestions');
                        });
                } else {
                    $suggestionsList.hide();
                }
            });

            $(document).on('click', '.suggestion-item', function (e) {
                e.stopPropagation();
                const $this = $(this);
                $('#addressInput').val($this.text());
                $('#suggestionsList').hide();

                $.getJSON('/Hotel/GetPlaceDetail', { placeId: $this.data('place-id') })
                    .done(data => {
                        $('#latInput').val(data.lat);
                        $('#lngInput').val(data.lng);
                    })
                    .fail(() => {
                        $('#latInput').val('');
                        $('#lngInput').val('');
                        console.error('Error fetching place details');
                    });
            });

            $(document).on('click', () => $('#suggestionsList').hide());
        });
    </script>
}

<style>
    #suggestionsList {
        position: absolute;
        z-index: 1000;
        width: calc(100% - 1rem);
    }

    .suggestion-item {
        cursor: pointer;
    }
</style>















