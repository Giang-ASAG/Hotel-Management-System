@model IEnumerable<DH52110843_web_quan_ly_khach_san_homestay.Models.Hotel>

@{
    ViewData["Title"] = "listhotel";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}


@if (ViewBag.Error != null)
{
    <p style="color:red;">@ViewBag.Error</p>
}
<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="m-0">Khách Sạn</h2>
        <a href="./create.html"><button class="btn btn-success">+ Thêm Mới</button></a>
    </div>

    <div class="alert alert-info alert-dismissible fade show" role="alert">
        Quản lý danh sách các khách sạn trong hệ thống.
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>

    <div class="d-flex justify-content-between mb-3">
        <button class="btn btn-outline-secondary btn-sm">Bộ lọc</button>
        <input type="text" class="form-control w-25" placeholder="Tìm kiếm khách sạn...">
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Tên Khách Sạn</th>
                    <th>Địa Chỉ</th>
                    <th>Số hotline</th>
                    <th>Địa chỉ email</th>
                    <th>Trạng thái</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @Html.DisplayFor(modelItem => item.HotelName)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Address)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.PhoneNumber)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Email)
                        </td>
                        <td>
                            @(item.Status == true ? "Hoạt động" : "Không hoạt động")
                        </td>
                        <td>
                            <div class="dropdown">
                                <button class="btn btn-sm btn-secondary dropdown-toggle" data-bs-toggle="dropdown">
                                    Tùy
                                    Chọn
                                </button>
                                <ul class="dropdown-menu">
                                  
                                    <li><a class="dropdown-item" asp-route-id="@item.UserId" asp-action="frmXoaBL">Chỉnh sửa</a></li>
                                    <li><a class="dropdown-item text-danger" asp-route-id="@item.UserId" asp-action="frmXoaBL">Xóa</a></li>
                                </ul>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>




